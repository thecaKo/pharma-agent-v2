<Project Sdk="WixToolset.Sdk/4.0.5">
  <PropertyGroup>
    <OutputName>PharmaAgentConnector</OutputName>
    <OutputType>Package</OutputType>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <StagingDir Condition="'$(StagingDir)' == ''">$(MSBuildThisFileDirectory)staging</StagingDir>
    <DefineConstants>StagingDir=$(StagingDir)</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WixToolset.UI.wixext" Version="4.0.5" />
    <PackageReference Include="WixToolset.Util.wixext" Version="4.0.5" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Package.wxs" />
    <Compile Include="Files.wxs" />
    <Compile Include="Service.wxs" />
    <Compile Include="ProgramData.wxs" />
    <Compile Include="UI.wxs" />
  </ItemGroup>
</Project>
