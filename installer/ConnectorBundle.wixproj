<Project Sdk="WixToolset.Sdk/4.0.5">
  <PropertyGroup>
    <OutputName>PharmaAgentConnector-Setup</OutputName>
    <OutputType>Bundle</OutputType>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WixToolset.BootstrapperApplications.wixext" Version="4.0.5" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Bundle.wxs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="ConnectorPackage.wixproj" />
  </ItemGroup>
</Project>
