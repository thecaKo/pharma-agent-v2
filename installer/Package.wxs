<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <?include Variables.wxi ?>

  <Package Name="$(var.ProductName)"
           Manufacturer="$(var.Manufacturer)"
           Version="$(var.ProductVersion)"
           UpgradeCode="$(var.UpgradeCode)"
           Scope="perMachine">
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <!-- Cab embutido: o MSI sai autocontido (um único arquivo instala tudo),
         sem depender dos .cab vizinhos em installer/bin/Release. -->
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ConnectorFeature" Title="Pharma Agent Connector" Level="1">
      <ComponentGroupRef Id="ConnectorApplicationFiles" />
      <ComponentGroupRef Id="ConnectorDistFiles" />
      <ComponentGroupRef Id="ConnectorNodeModulesFiles" />
      <ComponentGroupRef Id="ConnectorServiceComponents" />
      <ComponentRef Id="ProgramDataConnectorConfig" />
      <ComponentRef Id="ProgramDataConfigScript" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="PharmaAgentConnector" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="ProgramDataConnectorFolder" Name="$(var.ProgramDataDirName)" />
    </StandardDirectory>

    <UIRef Id="ConnectorInstallerUI" />
  </Package>
</Wix>
