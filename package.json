{
  "name": "@pharma-agent/connector",
  "version": "0.1.0",
  "description": "Local Pharma Agent connector runtime foundation.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "database-setup": "node dist/cli/database-setup.js",
    "discover-databases": "node dist/cli/discover-databases.js",
    "mock-panel": "node dist/cli/mock-panel.js",
    "package:windows-installer": "npm run build && node dist/installer/package-windows-installer.js",
    "start": "node dist/main.js",
    "start:dev": "NODE_ENV=dev LOG_FORMAT=pretty tsx src/main.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.1.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "mariadb": "^3.5.2",
    "mysql2": "^3.22.3",
    "node-firebird": "^2.3.2",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "ws": "^8.20.1"
  }
}
